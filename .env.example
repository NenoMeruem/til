# Google Drive Folder ID (Root folder where documents will be mirrored)
GDRIVE_FOLDER_ID=

# Path to Service Account JSON key file OR OAuth Client Secrets JSON file (e.g. tools/credentials.json)
# Or the raw JSON content string
GDRIVE_SERVICE_ACCOUNT_KEY=tools/credentials.json

# (Required for OAuth 2.0 User mode only) Path to stored user token (e.g. token.json)
# Or the raw JSON token content string
GDRIVE_TOKEN_PATH=token.json

# Local directory containing markdown documents to scan & mirror
DOCS_DIR=courses/Claude 101

# Local directory containing attachments/images to sync & remove
IMAGES_DIR=courses/Claude 101/images
